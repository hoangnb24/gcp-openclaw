#!/usr/bin/env bash
set -euo pipefail

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${BIN_DIR}/.." && pwd)"
STACK_LIB="${REPO_ROOT}/scripts/openclaw-gcp/lib-stack.sh"
WELCOME_SCRIPT="${REPO_ROOT}/scripts/openclaw-gcp/cloudshell-welcome.sh"

[[ -f "${STACK_LIB}" ]] || {
  echo "Error: missing stack helper library at ${STACK_LIB}" >&2
  exit 1
}
# shellcheck source=/dev/null
source "${STACK_LIB}"

usage() {
  cat <<EOF
Usage: $(basename "$0") <command> [options]

Phase 1 command surface for OpenClaw on GCP.

Commands:
  welcome   Run the non-mutating Cloud Shell welcome flow
  up        Validate stack inputs and print stack contract for bring-up wiring
  status    Show the active stack contract from local convenience state
  down      Validate stack inputs and print stack contract for teardown wiring
  help      Show this help text

Common options:
  --stack-id <id>      Explicit stack ID
  --lifecycle <name>   Lifecycle label value (default: persistent)
  --project-id <id>    Last-known project context (used for state write with up)
  --region <region>    Last-known region context (used for state write with up)
  --zone <zone>        Last-known zone context (used for state write with up)
  -h, --help           Show command help
EOF
}

command_usage() {
  local command_name="$1"
  cat <<EOF
Usage: $(basename "$0") ${command_name} [--stack-id <id>] [--lifecycle <name>] [--project-id <id>] [--region <region>] [--zone <zone>]
EOF
}

die() {
  echo "Error: $*" >&2
  exit 1
}

parse_common_args() {
  STACK_ID=""
  LIFECYCLE="${OPENCLAW_STACK_DEFAULT_LIFECYCLE}"
  PROJECT_ID=""
  REGION=""
  ZONE=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --stack-id)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --stack-id"
        STACK_ID="$2"
        shift 2
        ;;
      --lifecycle)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --lifecycle"
        LIFECYCLE="$2"
        shift 2
        ;;
      --project-id)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --project-id"
        PROJECT_ID="$2"
        shift 2
        ;;
      --region)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --region"
        REGION="$2"
        shift 2
        ;;
      --zone)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --zone"
        ZONE="$2"
        shift 2
        ;;
      -h|--help)
        command_usage "${COMMAND}"
        exit 0
        ;;
      *)
        die "unknown option for ${COMMAND}: $1"
        ;;
    esac
  done
}

resolve_stack_id() {
  local explicit="${1:-}" remembered=""
  if [[ -n "${explicit}" ]]; then
    oc_stack_require_id "${explicit}"
    return 0
  fi

  if remembered="$(oc_stack_state_get CURRENT_STACK_ID 2>/dev/null || true)"; then
    oc_stack_require_id "${remembered}"
    return 0
  fi

  die "no stack ID provided and no CURRENT_STACK_ID found in $(oc_stack_state_file)"
}

run_welcome() {
  [[ -x "${WELCOME_SCRIPT}" ]] || die "welcome script is not executable: ${WELCOME_SCRIPT}"
  exec "${WELCOME_SCRIPT}" "$@"
}

run_up() {
  parse_common_args "$@"
  STACK_ID="$(resolve_stack_id "${STACK_ID}")"
  oc_stack_state_write_current "${STACK_ID}" "${PROJECT_ID}" "${REGION}" "${ZONE}" "${LIFECYCLE}"

  cat <<EOF
[up] Phase 1 stack contract is ready.
The install-engine wiring lands in Story 2 follow-up work.

$(oc_stack_print_contract "${STACK_ID}" "${LIFECYCLE}")
EOF
}

run_status() {
  parse_common_args "$@"
  STACK_ID="$(resolve_stack_id "${STACK_ID}")"

  cat <<EOF
[status] Phase 1 stack contract snapshot.
The human-readable GCP discovery summary lands in Story 3 follow-up work.

$(oc_stack_print_contract "${STACK_ID}" "${LIFECYCLE}")
EOF
}

run_down() {
  parse_common_args "$@"
  STACK_ID="$(resolve_stack_id "${STACK_ID}")"

  cat <<EOF
[down] Phase 1 stack contract is resolved.
Destroy-engine wiring lands in Story 3 follow-up work.

$(oc_stack_print_contract "${STACK_ID}" "${LIFECYCLE}")
EOF
}

COMMAND="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "${COMMAND}" in
  welcome)
    run_welcome "$@"
    ;;
  up)
    run_up "$@"
    ;;
  status)
    run_status "$@"
    ;;
  down)
    run_down "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    die "unknown command: ${COMMAND}"
    ;;
esac
