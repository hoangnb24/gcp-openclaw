#!/usr/bin/env bash
set -euo pipefail

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${BIN_DIR}/.." && pwd)"
STACK_LIB="${REPO_ROOT}/scripts/openclaw-gcp/lib-stack.sh"
WELCOME_SCRIPT="${REPO_ROOT}/scripts/openclaw-gcp/cloudshell-welcome.sh"
INSTALL_SCRIPT="${REPO_ROOT}/scripts/openclaw-gcp/install.sh"

[[ -f "${STACK_LIB}" ]] || {
  echo "Error: missing stack helper library at ${STACK_LIB}" >&2
  exit 1
}
# shellcheck source=/dev/null
source "${STACK_LIB}"

usage() {
  cat <<EOF
Usage: $(basename "$0") <command> [options]

Phase 1 command surface for OpenClaw on GCP.

Commands:
  welcome   Run the non-mutating Cloud Shell welcome flow
  up        Run stack-native bring-up through the existing install engine
  status    Show the active stack contract from local convenience state
  down      Validate stack inputs and print stack contract for teardown wiring
  help      Show this help text

Common options:
  --stack-id <id>      Explicit stack ID
  --lifecycle <name>   Lifecycle label value (default: persistent)
  --project-id <id>    Last-known project context (used for state write with up)
  --region <region>    Last-known region context (used for state write with up)
  --zone <zone>        Last-known zone context (used for state write with up)
  -h, --help           Show command help

`up` passthrough options:
  --openclaw-tag <tag>      Forwarded to install.sh
  --openclaw-image <image>  Forwarded to install.sh
  --service-account <email> Forwarded to install.sh
  --scopes <csv>            Forwarded to install.sh
  --no-service-account      Forwarded to install.sh
  --allow-external-ip       Forwarded to install.sh
  --interactive             Forwarded to install.sh
  --non-interactive         Forwarded to install.sh
  --dry-run                 Forwarded to install.sh
EOF
}

command_usage() {
  local command_name="$1"
  cat <<EOF
Usage: $(basename "$0") ${command_name} [--stack-id <id>] [--lifecycle <name>] [--project-id <id>] [--region <region>] [--zone <zone>]
EOF
}

die() {
  echo "Error: $*" >&2
  exit 1
}

parse_common_args() {
  STACK_ID=""
  LIFECYCLE="${OPENCLAW_STACK_DEFAULT_LIFECYCLE}"
  PROJECT_ID=""
  REGION=""
  ZONE=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --stack-id)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --stack-id"
        STACK_ID="$2"
        shift 2
        ;;
      --lifecycle)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --lifecycle"
        LIFECYCLE="$2"
        shift 2
        ;;
      --project-id)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --project-id"
        PROJECT_ID="$2"
        shift 2
        ;;
      --region)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --region"
        REGION="$2"
        shift 2
        ;;
      --zone)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --zone"
        ZONE="$2"
        shift 2
        ;;
      -h|--help)
        command_usage "${COMMAND}"
        exit 0
        ;;
      *)
        die "unknown option for ${COMMAND}: $1"
        ;;
    esac
  done
}

parse_up_args() {
  STACK_ID=""
  LIFECYCLE="${OPENCLAW_STACK_DEFAULT_LIFECYCLE}"
  PROJECT_ID=""
  REGION=""
  ZONE=""
  UP_DRY_RUN="false"
  INSTALL_PASSTHROUGH_ARGS=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --stack-id)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --stack-id"
        STACK_ID="$2"
        shift 2
        ;;
      --lifecycle)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --lifecycle"
        LIFECYCLE="$2"
        shift 2
        ;;
      --project-id)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --project-id"
        PROJECT_ID="$2"
        shift 2
        ;;
      --region)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --region"
        REGION="$2"
        shift 2
        ;;
      --zone)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for --zone"
        ZONE="$2"
        shift 2
        ;;
      --openclaw-tag|--openclaw-image|--service-account|--scopes)
        [[ -n "${2-}" && "${2}" != --* ]] || die "missing value for $1"
        INSTALL_PASSTHROUGH_ARGS+=("$1" "$2")
        shift 2
        ;;
      --no-service-account|--allow-external-ip|--interactive|--non-interactive)
        INSTALL_PASSTHROUGH_ARGS+=("$1")
        shift
        ;;
      --dry-run)
        UP_DRY_RUN="true"
        INSTALL_PASSTHROUGH_ARGS+=("$1")
        shift
        ;;
      -h|--help)
        command_usage "${COMMAND}"
        exit 0
        ;;
      *)
        die "unknown option for ${COMMAND}: $1"
        ;;
    esac
  done
}

resolve_stack_id() {
  local explicit="${1:-}" remembered=""
  if [[ -n "${explicit}" ]]; then
    oc_stack_require_id "${explicit}"
    return 0
  fi

  if remembered="$(oc_stack_state_get CURRENT_STACK_ID 2>/dev/null || true)"; then
    oc_stack_require_id "${remembered}"
    return 0
  fi

  die "no stack ID provided and no CURRENT_STACK_ID found in $(oc_stack_state_file)"
}

run_welcome() {
  [[ -x "${WELCOME_SCRIPT}" ]] || die "welcome script is not executable: ${WELCOME_SCRIPT}"
  exec "${WELCOME_SCRIPT}" "$@"
}

run_up() {
  parse_up_args "$@"
  STACK_ID="$(resolve_stack_id "${STACK_ID}")"
  local instance_name template_name router_name nat_name labels_csv
  local resolved_project resolved_region resolved_zone
  local -a install_cmd

  instance_name="$(oc_stack_instance_name "${STACK_ID}")"
  template_name="$(oc_stack_template_name "${STACK_ID}")"
  router_name="$(oc_stack_router_name "${STACK_ID}")"
  nat_name="$(oc_stack_nat_name "${STACK_ID}")"
  labels_csv="$(oc_stack_labels_csv "${STACK_ID}" "${LIFECYCLE}")"

  install_cmd=(
    bash "${INSTALL_SCRIPT}"
    --instance-name "${instance_name}"
    --template-name "${template_name}"
    --router-name "${router_name}"
    --nat-name "${nat_name}"
    --resource-labels "${labels_csv}"
  )
  [[ -n "${PROJECT_ID}" ]] && install_cmd+=(--project-id "${PROJECT_ID}")
  [[ -n "${REGION}" ]] && install_cmd+=(--region "${REGION}")
  [[ -n "${ZONE}" ]] && install_cmd+=(--zone "${ZONE}")
  install_cmd+=("${INSTALL_PASSTHROUGH_ARGS[@]}")

  cat <<EOF
[up] Stack contract resolved.
Delegating bring-up to scripts/openclaw-gcp/install.sh with derived names.

$(oc_stack_print_contract "${STACK_ID}" "${LIFECYCLE}")
EOF

  "${install_cmd[@]}"

  if [[ "${UP_DRY_RUN}" == "true" ]]; then
    echo "Dry-run mode: skipping current-stack state write."
    return 0
  fi

  resolved_project="${PROJECT_ID}"
  if [[ -z "${resolved_project}" ]] && command -v gcloud >/dev/null 2>&1; then
    resolved_project="$(gcloud config get-value project 2>/dev/null || true)"
    [[ "${resolved_project}" == "(unset)" ]] && resolved_project=""
  fi
  resolved_region="${REGION:-asia-southeast1}"
  resolved_zone="${ZONE:-asia-southeast1-a}"
  oc_stack_state_write_current "${STACK_ID}" "${resolved_project}" "${resolved_region}" "${resolved_zone}" "${LIFECYCLE}"
  echo "Saved current stack convenience state to $(oc_stack_state_file)"
}

run_status() {
  parse_common_args "$@"
  STACK_ID="$(resolve_stack_id "${STACK_ID}")"
  local state_lifecycle
  local status_project_id status_region status_zone
  local instance_name template_name router_name nat_name
  local labels_csv
  local instance_status template_status router_status nat_status
  local context_note=""

  if [[ "${LIFECYCLE}" == "${OPENCLAW_STACK_DEFAULT_LIFECYCLE}" ]]; then
    state_lifecycle="$(oc_stack_state_get_or_empty LIFECYCLE)"
    [[ -n "${state_lifecycle}" ]] && LIFECYCLE="${state_lifecycle}"
  fi

  status_project_id="${PROJECT_ID}"
  [[ -z "${status_project_id}" ]] && status_project_id="$(oc_stack_state_get_or_empty LAST_PROJECT_ID)"
  if [[ -z "${status_project_id}" ]] && command -v gcloud >/dev/null 2>&1; then
    status_project_id="$(gcloud config get-value project 2>/dev/null || true)"
    [[ "${status_project_id}" == "(unset)" ]] && status_project_id=""
  fi

  status_region="${REGION}"
  [[ -z "${status_region}" ]] && status_region="$(oc_stack_state_get_or_empty LAST_REGION)"
  [[ -z "${status_region}" ]] && status_region="asia-southeast1"

  status_zone="${ZONE}"
  [[ -z "${status_zone}" ]] && status_zone="$(oc_stack_state_get_or_empty LAST_ZONE)"
  [[ -z "${status_zone}" ]] && status_zone="${status_region}-a"

  instance_name="$(oc_stack_instance_name "${STACK_ID}")"
  template_name="$(oc_stack_template_name "${STACK_ID}")"
  router_name="$(oc_stack_router_name "${STACK_ID}")"
  nat_name="$(oc_stack_nat_name "${STACK_ID}")"
  labels_csv="$(oc_stack_labels_csv "${STACK_ID}" "${LIFECYCLE}")"

  if ! command -v gcloud >/dev/null 2>&1; then
    instance_status="unknown (gcloud not available in PATH)"
    template_status="unknown (gcloud not available in PATH)"
    router_status="unknown (gcloud not available in PATH)"
    nat_status="unknown (gcloud not available in PATH)"
    context_note="Install gcloud or run inside Cloud Shell to get live resource existence checks."
  elif [[ -z "${status_project_id}" ]]; then
    instance_status="unknown (missing project context)"
    template_status="unknown (missing project context)"
    router_status="unknown (missing project context)"
    nat_status="unknown (missing project context)"
    context_note="Pass --project-id or run 'up' once to persist LAST_PROJECT_ID in $(oc_stack_state_file)."
  else
    if gcloud compute instances describe "${instance_name}" --project "${status_project_id}" --zone "${status_zone}" --format='value(name)' >/dev/null 2>&1; then
      instance_status="present"
    else
      instance_status="missing"
    fi

    if gcloud compute instance-templates describe "${template_name}" --project "${status_project_id}" --region "${status_region}" --format='value(name)' >/dev/null 2>&1; then
      template_status="present"
    else
      template_status="missing"
    fi

    if gcloud compute routers describe "${router_name}" --project "${status_project_id}" --region "${status_region}" --format='value(name)' >/dev/null 2>&1; then
      router_status="present"
    else
      router_status="missing"
    fi

    if gcloud compute routers nats describe "${nat_name}" --project "${status_project_id}" --router "${router_name}" --region "${status_region}" --format='value(name)' >/dev/null 2>&1; then
      nat_status="present"
    else
      nat_status="missing"
    fi
  fi

  cat <<EOF
OpenClaw GCP Stack Status
=========================
stack_id: ${STACK_ID}
lifecycle: ${LIFECYCLE}

Context
  project_id: ${status_project_id:-<unknown>}
  region: ${status_region}
  zone: ${status_zone}

Managed Resources (expected for this stack)
  instance (${instance_name}): ${instance_status}
  template (${template_name}): ${template_status}
  router (${router_name}): ${router_status}
  nat (${nat_name}): ${nat_status}

Ownership Contract
  label selector for labelable resources: ${labels_csv}
  deterministic companion names for router/nat derive from stack_id

Local Convenience State
  state_file: $(oc_stack_state_file)
  current_stack_id: $(oc_stack_state_get_or_empty CURRENT_STACK_ID)

EOF

  if [[ -n "${context_note}" ]]; then
    echo
    echo "Note: ${context_note}"
  fi
}

run_down() {
  parse_common_args "$@"
  STACK_ID="$(resolve_stack_id "${STACK_ID}")"

  cat <<EOF
[down] Phase 1 stack contract is resolved.
Destroy-engine wiring lands in Story 3 follow-up work.

$(oc_stack_print_contract "${STACK_ID}" "${LIFECYCLE}")
EOF
}

COMMAND="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "${COMMAND}" in
  welcome)
    run_welcome "$@"
    ;;
  up)
    run_up "$@"
    ;;
  status)
    run_status "$@"
    ;;
  down)
    run_down "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    die "unknown command: ${COMMAND}"
    ;;
esac
